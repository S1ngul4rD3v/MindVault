{
  "name": "mindvault",
  "version": "1.0.0",
  "description": "MindVault",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "node -r dotenv/config node_modules/.bin/sequelize-cli db:migrate",
    "migrate:undo": "node -r dotenv/config node_modules/.bin/sequelize-cli db:migrate:undo",
    "migrate:status": "node -r dotenv/config node_modules/.bin/sequelize-cli db:migrate:status"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.2.2",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "pg": "^8.18.0",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.5"
  }
}
